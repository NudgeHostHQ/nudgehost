NEXT_PUBLIC_SITE_URL=https://www.nudgehost.com

# Clerk authentication. Publishable key is the test pk_test_* value from
# the Clerk dashboard; secret key is set in Vercel and left blank locally.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Cloudflare Turnstile, required for anonymous (signed-out) uploads. With
# either key missing, anonymous uploads are disabled and signed-out visitors
# are sent to sign-up instead (the pre-Turnstile behavior). The site key is
# inlined into the client at build time; the secret stays server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare R2 (S3-compatible object storage) for file uploads.
# Endpoint looks like https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Stripe payments. Publishable + secret keys from the Stripe dashboard, the
# price IDs for the Pro and Team subscriptions, and the webhook signing secret
# (from the Stripe webhook endpoint config).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Shared secret gating POST /api/admin/regenerate-thumbnails, the one-off
# thumbnail backfill. Set to a long random string. Leave blank to disable the
# route entirely (it fails closed when this is unset).
THUMBNAIL_BACKFILL_SECRET=

# Shared secret gating POST /api/admin/ban (abuse takedowns, operated via
# curl). Generate with: openssl rand -hex 32. Fails closed when unset.
ADMIN_SECRET=

# Shared secret gating the daily cleanup cron (/api/cron/cleanup-expired).
# Vercel sends it automatically as "Authorization: Bearer <value>" on cron
# invocations when this env var is set. Generate with: openssl rand -hex 32.
# The route fails closed (401) when unset.
CRON_SECRET=
